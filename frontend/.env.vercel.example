# Vercel project settings (Root Directory = `frontend`)
# Set these in the Vercel dashboard → Settings → Environment Variables (Production).

# Leadership static build: no FastAPI / DuckDB — charts load from /data/snapshots
NEXT_PUBLIC_DATA_MODE=static
NEXT_PUBLIC_LEADERSHIP_MODE=true
NEXT_PUBLIC_ENABLE_UPLOAD=false
NEXT_PUBLIC_ENABLE_LSQ_SYNC=false
NEXT_PUBLIC_AUTO_LOGIN=false

# Do NOT set NEXT_PUBLIC_API_URL for this mode (rewrites are disabled).

# Publish workflow (from your PC, after local upload/sync):
#   python backend/scripts/publish_snapshots.py
#   git add frontend/public/data/snapshots && git commit && git push
# Or: vercel --prod from frontend/ with snapshots already generated.
