# Vercel project settings (Root Directory = frontend)
# Set these in the Vercel dashboard → Settings → Environment Variables (Production).
# Do not commit real secrets or production passwords if you rotate them.

NEXT_PUBLIC_API_URL=https://YOUR-BACKEND.up.railway.app
NEXT_PUBLIC_ENABLE_UPLOAD=false
NEXT_PUBLIC_ENABLE_LSQ_SYNC=false
NEXT_PUBLIC_AUTO_LOGIN=true
NEXT_PUBLIC_DEFAULT_USER=ops
NEXT_PUBLIC_DEFAULT_PASSWORD=ops123
