# Application
APP_NAME=DP Analytics Platform
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-long-random-string
API_PREFIX=/api/v1

# Storage
DATA_DIR=./data
PARQUET_DIR=./data/parquet
METADATA_DB_URL=sqlite:///./data/metadata.db
DUCKDB_PATH=./data/analytics.duckdb

# Upload limits
MAX_UPLOAD_SIZE_MB=5120
MAX_FILES_PER_BATCH=100
ALLOWED_EXTENSIONS=.xlsx,.xls,.csv,.zip

# Auth
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# CORS — include Vercel URL when deploying the public dashboard
CORS_ORIGINS=http://localhost:3000

# Cache
ANALYTICS_CACHE_TTL_SECONDS=300

# Logging
LOG_LEVEL=INFO

# LeadSquared live sync (secrets — never commit real values)
# Public Railway/Render host: keep LEADSQUARED_SYNC_ENABLED=false
LEADSQUARED_ACCESS_KEY=
LEADSQUARED_SECRET_KEY=
LEADSQUARED_API_HOST=https://api-in21.leadsquared.com/v2
LEADSQUARED_SYNC_ENABLED=false
LEADSQUARED_PAGE_SIZE=1000
LEADSQUARED_SYNC_WORKERS=3
SYNC_ADMIN_TOKEN=
